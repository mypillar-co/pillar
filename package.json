{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
  "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
  "build": "pnpm run typecheck && pnpm -r --if-present run build",
  "typecheck:libs": "tsc --build",
  "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
  "test:e2e": "playwright test",
  "test:e2e:ui": "playwright test --ui",
  "test:core": "playwright test artifacts/e2e/01-platform-health.spec.ts artifacts/e2e/27-dashboard-navigation.spec.ts artifacts/e2e/29-public-site-rendering.spec.ts --config=artifacts/playwright.config.ts --project=desktop-chrome --workers=1 --reporter=line",
  "test:branded-hero": "playwright test artifacts/e2e/81-branded-hero-banner.spec.ts --config=artifacts/playwright.config.ts --project=desktop-chrome --workers=1 --reporter=line",
  "test:site-archetypes": "playwright test artifacts/e2e/89-site-archetype-lodge.spec.ts artifacts/e2e/90-site-archetype-civic.spec.ts artifacts/e2e/91-site-archetype-quality-gates.spec.ts --config=artifacts/playwright.config.ts --project=desktop-chrome --workers=1 --reporter=line",
  "doctor": "node scripts/doctor.mjs"
},
  "private": true,
  "devDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.2",
    "@tailwindcss/oxide-darwin-arm64": "^4.2.4",
    "lightningcss-darwin-arm64": "^1.32.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@playwright/test": "^1.59.0",
    "@types/pg": "^8.18.0",
    "axios": "^1.14.0",
    "chromium-bidi": "^15.0.0",
    "cookie-parser": "^1.4.7",
    "pg": "^8.20.0",
    "playwright": "^1.59.0",
    "playwright-core": "^1.59.0",
    "puppeteer": "^24.40.0",
    "stripe": "20.0.0",
    "stripe-replit-sync": "1.0.0",
    "zod-to-json-schema": "^3.25.2"
  }
}
