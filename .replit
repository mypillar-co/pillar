modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/community-platform"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "E2E Health Check"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Playwright E2E"

[[workflows.workflow]]
name = "E2E Health Check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run e2e"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Playwright E2E"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm exec playwright test --config=artifacts/playwright.config.ts"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
